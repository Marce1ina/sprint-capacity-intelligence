---
import AppNav from "@/components/AppNav.astro";

const { user } = Astro.locals;
---

{
  user ? (
    <AppNav />
  ) : (
    <div class="mb-4 flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/80">
      <span class="text-blue-100/70">Not signed in</span>
      <a href="/auth/signin" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
        Sign in
      </a>
    </div>
  )
}
