---
import Layout from "@/layouts/Layout.astro";
import SprintPicker from "@/components/dashboard/SprintPicker";

const { user } = Astro.locals;
---

<Layout title="Dashboard">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-3xl rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h1
            class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent"
          >
            Sprint capacity
          </h1>
          <p class="text-sm text-blue-100/80">
            Signed in as <span class="font-semibold text-white">{user?.email}</span>
          </p>
        </div>
        <form method="POST" action="/api/auth/signout" class="shrink-0">
          <button
            type="submit"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
          >
            Sign out
          </button>
        </form>
      </div>

      <SprintPicker client:load />
    </div>
  </div>
</Layout>
