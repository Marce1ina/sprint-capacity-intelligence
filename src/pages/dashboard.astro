---
import AppNav from "@/components/AppNav.astro";
import Layout from "@/layouts/Layout.astro";
import SprintPicker from "@/components/dashboard/SprintPicker";
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4">
    <div class="mx-auto w-full max-w-3xl">
      <AppNav />
      <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
        <h1 class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Sprint capacity
        </h1>
        <SprintPicker client:load />
      </div>
    </div>
  </div>
</Layout>
