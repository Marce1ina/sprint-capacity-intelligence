---
import Layout from "@/layouts/Layout.astro";
import { ServerError } from "@/components/auth/ServerError";
import { resolveInviteAdminService } from "@/lib/invite-api-context";

const { token } = Astro.params;
const errorParam = Astro.url.searchParams.get("error");
const justConnected = Astro.url.searchParams.get("connected") === "1";

const service = resolveInviteAdminService();
const invite = service && token ? await service.getInviteByToken(token) : null;

const configError = !service;
const invalidLink = !configError && !invite;
const alreadyUsed = !configError && !!invite && invite.status === "consumed" && !justConnected;
const showConnect = !configError && !!invite && invite.status === "pending";
---

<Layout title="Connect Google Calendar">
  <div class="bg-cosmic min-h-screen p-4">
    <div class="mx-auto max-w-md">
      <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
        <h1 class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
          Connect Google Calendar
        </h1>

        {configError && <ServerError message="Service is temporarily unavailable. Please try again later." />}

        {invalidLink && <ServerError message="This invite link is invalid." />}

        {
          alreadyUsed && (
            <p class="text-sm text-blue-100/80">This invite link has already been used to connect a calendar.</p>
          )
        }

        {
          justConnected && invite && (
            <p class="text-sm text-blue-100/80">
              Calendar connected for <strong>{invite.jiraDisplayName}</strong>. You can close this page.
            </p>
          )
        }

        {
          showConnect && (
            <>
              <p class="mb-6 text-sm text-blue-100/80">
                <strong>{invite.jiraDisplayName}</strong> was invited to connect Google Calendar for sprint #
                {invite.sprintId} so their meeting load can be included in the sprint risk analysis.
              </p>
              {errorParam && <ServerError message={errorParam} />}
              <a
                href={`/api/invite/${token}/start`}
                class="mt-4 inline-block rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm text-white transition-colors hover:bg-white/20"
              >
                Connect Google Calendar
              </a>
            </>
          )
        }
      </div>
    </div>
  </div>
</Layout>
