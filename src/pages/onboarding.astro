---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Onboarding">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div
      class="w-full max-w-md rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl"
    >
      <h1 class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
        Jira setup
      </h1>
      <p class="text-blue-100/80">Jira PAT configuration is coming in the next step of onboarding.</p>
    </div>
  </div>
</Layout>
