# User or team service-account key from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_...

# Required: precomputed PR diff (use one of the two below)
# REVIEW_DIFF_FILE=/tmp/pr.diff
# REVIEW_DIFF=...

# Optional PR context
# REVIEW_PR_TITLE=
# REVIEW_PR_BODY=

# Repository root the local agent runs against (defaults to parent directory)
# REVIEW_CWD=..

# Model ID (defaults to composer-2.5)
# REVIEW_MODEL=composer-2.5

# Max agent tool-use rounds before cancelling (defaults to 5)
# REVIEW_MAX_ROUNDS=5

# --- Eval suite (npm run eval) ---
# CURSOR_API_KEY is required. Full matrix ≈ 12 paid Cursor agent runs
# (3 models × 4 fixtures). Model ids live in eval/models.json.
# Promptfoo is not required for npm run review / advisory CI.
