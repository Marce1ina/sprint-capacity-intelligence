SUPABASE_URL=
SUPABASE_KEY=
# Supabase Dashboard → Settings → API → service_role (server-only; never expose to client)
SUPABASE_SERVICE_ROLE_KEY=
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
# For local `supabase start` Google OAuth (see README Supabase Configuration)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
