SUPABASE_URL=
SUPABASE_KEY=
# Supabase Dashboard → Settings → API → service_role (server-only; never expose to client)
SUPABASE_SERVICE_ROLE_KEY=
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
# Optional: local RLS integration tests (npm run test:rls) — requires `npx supabase start`
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
TEST_USER_B_EMAIL=
TEST_USER_B_PASSWORD=
# For local `supabase start` Google OAuth (see README Supabase Configuration)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
